# ================================================
# Copy this file to .env.dev and fill in the values
# Usage: docker compose --env-file .env.dev -f docker-compose.dev.yml up --build
# ================================================

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Spring Boot profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT signing secret (min 32 chars — generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_STRING
JWT_EXPIRATION_MS=86400000

# Cookie configuration
COOKIE_SECURE=false
FRONTEND_URL=http://localhost:5173

# Google OAuth2 (optional)
# Get credentials from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Used by backend (runtime) and frontend Docker build (build arg)
GOOGLE_CLIENT_ID=

# Email provider (noop = logs to console, resend = sends via Resend API)
EMAIL_PROVIDER=noop
EMAIL_FROM=noreply@example.com
# Required only when EMAIL_PROVIDER=resend (get key from https://resend.com)
RESEND_API_KEY=

# Cloudflare R2 Image Storage (optional in dev — defaults to noop)
# Set STORAGE_PROVIDER=r2 and fill in credentials to enable R2 storage
STORAGE_PROVIDER=noop
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# Stripe (optional in dev — required in prod)
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Webhook secret: use Stripe CLI in dev: stripe listen --forward-to localhost:8080/api/v1/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# AI Image Analysis (noop = disabled, ollama = local/remote LLM, gemini = Google Gemini API)
AI_PROVIDER=noop
# Ollama server URL (local: http://localhost:11434, Docker: http://host.docker.internal:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Vision model to use for analysis
OLLAMA_MODEL=gemma3:4b
# Extra allowed hosts for Ollama URL validation (comma-separated, e.g. for Railway: ollama.railway.internal)
OLLAMA_ALLOWED_HOSTS=
# Gemini API (required only when AI_PROVIDER=gemini — get key from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=30
GEMINI_THREAD_POOL=2

# Sentry error monitoring (optional — leave empty to disable)
# Backend DSN (server-side, keep secret)
SENTRY_DSN=
# Frontend DSN (public, bundled into JS — safe to expose)
VITE_SENTRY_DSN=
