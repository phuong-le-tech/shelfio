# ================================================
# Production environment variables
# Copy this file to .env.prod and fill in the values
# Usage: docker compose --env-file .env.prod up --build
# ================================================

# Spring Boot profile
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL connection (Railway: use ${{Postgres.PGHOST}} etc.)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
# Connection pool size (Railway shared DB allows ~20 connections)
DB_POOL_SIZE=5

# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# CORS allowed origins (your frontend URL)
CORS_ALLOWED_ORIGINS=https://your-frontend.railway.app

# Cookie configuration
COOKIE_SECURE=true
FRONTEND_URL=https://your-frontend.railway.app

# Google OAuth2 (optional — leave empty to disable)
GOOGLE_CLIENT_ID=

# Email provider (resend = sends via Resend API)
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@yourdomain.com
RESEND_API_KEY=

# Cloudflare R2 Image Storage (set STORAGE_PROVIDER=r2 to enable)
STORAGE_PROVIDER=r2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=inventory-images

# Stripe (optional — leave empty to disable payment features)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI Image Analysis (noop = disabled, ollama = local/remote LLM, gemini = Google Gemini API)
AI_PROVIDER=noop
# Ollama settings (required only when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=
OLLAMA_MODEL=gemma3:4b
OLLAMA_ALLOWED_HOSTS=
# Gemini settings (required only when AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=30
GEMINI_THREAD_POOL=2

# Sentry error monitoring (optional — leave empty to disable)
SENTRY_DSN=
VITE_SENTRY_DSN=
